{
  "name": "cursor-remote",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n server,frontend -c blue,green \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm run build:server && npm run build:frontend",
    "build:server": "tsc -p tsconfig.server.json",
    "build:frontend": "npm --prefix frontend run build",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && npm --prefix frontend run typecheck",
    "test": "vitest run",
    "test:ui": "vitest run --run frontend/src/timeline.test.ts frontend/src/App.test.tsx",
    "coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "@cursor/sdk": "latest",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "happy-dom": "^20.9.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
