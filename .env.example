# Server port for the local API wrapper.
PORT=8787

# Bind to 0.0.0.0 when exposing through LAN/Tailscale. Keep localhost-only by
# setting HOST=127.0.0.1 during local-only debugging.
HOST=0.0.0.0

# Cursor SDK auth. Keep this server-side only.
# Plain text (do not commit real keys):
#   CURSOR_API_KEY=...
# Or a 1Password secret reference — resolve at runtime with:
#   ./scripts/dev-op.sh   OR   npm run dev:op
CURSOR_API_KEY=
# Example OP reference (matches vault/item/field):
# CURSOR_API_KEY=op://dev/dev-api-keys/cursor_api_key

# Runtime can be mock or local. Mock mode needs no token. Stage 1 product mode is
# local: the Node backend runs on the machine that owns CURSOR_LOCAL_CWD.
CURSOR_RUNTIME=local

# Local runtime working directory. For self-bootstrapping, point Cursor at this
# repo root so the app can eventually edit itself. Live tests still create their
# own temporary sandbox and must not modify the real repo.
CURSOR_LOCAL_CWD=/Users/grapeot/co/knowledge_working/adhoc_jobs/cursor_cloud_remote_poc

# Default Cursor model for product and live evaluation.
CURSOR_DEFAULT_MODEL=composer-2
