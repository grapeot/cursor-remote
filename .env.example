# Server port for the local API wrapper.
PORT=8787

# Cursor SDK auth. Keep this server-side only.
# Plain text (do not commit real keys):
#   CURSOR_API_KEY=...
# Or a 1Password secret reference — resolve at runtime with:
#   ./scripts/dev-op.sh   OR   npm run dev:op
CURSOR_API_KEY=
# Example OP reference (matches vault/item/field):
# CURSOR_API_KEY=op://dev/dev-api-keys/cursor_api_key

# Runtime can be mock, local, or cloud. Mock mode needs no token.
# For the target remote-control validation, use local: the Node backend runs on
# your Mac and Cursor SDK works inside CURSOR_LOCAL_CWD.
CURSOR_RUNTIME=mock

# Local runtime working directory. Absolute path to this project root for the MVP
# (agent writes mvp_sandbox/hello_world.py here). Required when CURSOR_RUNTIME=local.
CURSOR_LOCAL_CWD=

# Optional defaults used when starting cloud runs.
CURSOR_DEFAULT_REPO_URL=
CURSOR_DEFAULT_REF=main
CURSOR_DEFAULT_MODEL=composer-2
