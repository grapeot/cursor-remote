# Server port for the local API wrapper.
PORT=8787

# Bind address (e.g. 127.0.0.1 for local-only).
HOST=0.0.0.0

# Cursor SDK credential — server-side only; never commit a real secret.
# Obtain a key from Cursor account / developer settings and paste below.
CURSOR_API_KEY=<CURSOR_API_TOKEN>

# mock | local | cloud (local expects CURSOR_LOCAL_CWD).
CURSOR_RUNTIME=local

# Working directory Cursor uses for local runs — relative paths resolve from the
# process cwd where you started the backend (typically the repo root). Live tests use a temp sandbox, not your real repo unless you intentionally point there.
CURSOR_LOCAL_CWD=.

CURSOR_DEFAULT_MODEL=composer-2

# Cloud runtime only — Git repository URL Cursor should use.
# CURSOR_DEFAULT_REPO_URL=https://github.com/<owner>/<repo>
